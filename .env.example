# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# KakaoTalk REST API
# 발급 방법: https://developers.kakao.com → 앱 생성 → REST API 키 복사
KAKAO_REST_API_KEY=...
# 아래 토큰은 kakao_auth.py 실행 후 자동으로 .env에 저장됩니다
KAKAO_REFRESH_TOKEN=...

# 모니터링할 종목 (쉼표로 구분, 티커 심볼)
STOCKS=NVDA,AAPL,TSLA

# 알람 시간 (24시간 기준, KST)
ALARM_HOUR=8
ALARM_MINUTE=0
